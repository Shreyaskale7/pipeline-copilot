# Copy this file to `.env` and fill in your real key. `.env` is git-ignored.
#
# ADK reads GOOGLE_API_KEY (NOT GEMINI_API_KEY) when using the AI Studio path.
GOOGLE_API_KEY=your-gemini-api-key-here

# Use the AI Studio key path instead of Vertex AI. Must be FALSE for the key above.
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Shared secret that gates writes to the CRM (log_activity). The MCP server reads
# this from its environment; the agent's toolset passes the same value through.
# Defaults to "demo-token" everywhere so the demo works out of the box.
CRM_API_TOKEN=demo-token
